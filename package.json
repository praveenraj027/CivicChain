{
    "name": "crowdpulse",
    "version": "2.1.0",
    "description": "CrowdPulse — Decentralised Civic Intelligence on SAYMAN Blockchain",
    "type": "module",
    "scripts": {
      "deploy:local":   "SAYMAN_RPC=http://localhost:10000 node scripts/deploy.js --network=local",
      "deploy:testnet": "node scripts/deploy.js --network=testnet",
      "deploy:mainnet": "node scripts/deploy.js --network=mainnet",
      "backend":        "node backend/index.js",
      "backend:dev":    "SAYMAN_RPC=http://localhost:10000 node backend/index.js",
      "frontend":       "cd frontend && npm run dev",
      "dev": "concurrently \"npm run backend:dev\" \"npm run frontend\"",
      "build":          "cd frontend && npm run build"
    },
    "dependencies": {
      "cors": "^2.8.5",
      "dotenv": "^17.4.2",
      "elliptic": "^6.5.7",
      "express": "^4.18.2",
      "express-rate-limit": "^7.4.1",
      "helmet": "^8.0.0"
    },
    "devDependencies": {
      "concurrently": "^9.1.0"
    }
  }